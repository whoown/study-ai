# OpenAI 风格接口配置
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# 可选：Embedding 专用服务（第 13 小时起会用到）
# 像 DeepSeek / Moonshot 这类只提供 Chat、不提供 /embeddings 的兼容服务，
# 需要单独配置一个支持 embedding 的服务，否则会降级为哈希伪向量。
# OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_API_KEY=your_embedding_api_key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 可选：第 24 小时 FastAPI 服务地址
HOUR24_HOST=127.0.0.1
HOUR24_PORT=8000
